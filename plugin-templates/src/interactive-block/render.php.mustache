<?php
	/**
	 * Block Template File.
	 *
	 * @package    {{pascaleNamespace}}/{{slugPascalCase}}
	 * @since      {{version}}
	 * @version    {{version}}
	 */

	namespace {{pascaleNamespace}}\{{slugPascalCase}};

	defined( 'ABSPATH' ) || die( 'Keep Silent' );

	/**
	 * Interactive Block Template.
	 *
	 * @var array<string, mixed> $attributes - A clean associative array of block attributes.
	 * @var \WP_Block             $block     - The block instance. All the block settings and attributes.
	 * @var string               $content    - The block inner HTML (usually empty unless using inner blocks).
	 */

	${{namespace}}_unique_id = uniqid( 'p-' );

	${{namespace}}_classes = array(
		'class-01' => true,
	);

	${{namespace}}_styles = array(
		'--css-variable' => $attributes['x'] . '%',
	);

	${{namespace}}_context = $block->context;

	${{namespace}}_wrapper_attributes = get_block_wrapper_attributes(
		array(
			'class' => esc_attr( get_blocks()->get_css_classes( ${{namespace}}_classes ) ),
			'style' => esc_attr( get_blocks()->get_inline_styles( ${{namespace}}_styles ) ),
		)
	);

	${{namespace}}_allowed_html = get_blocks()->get_kses_allowed_html();
	?>

<div <?php echo wp_kses_data( ${{namespace}}_wrapper_attributes ); ?> data-wp-interactive="{{namespace}}" <?php echo wp_kses_data( wp_interactivity_data_wp_context( array( 'isOpen' => false ) ) ); ?> data-wp-watch="callbacks.logIsOpen">
	<h1>{{title}} – interactive block render.php</h1>
	<button data-wp-on--click="actions.toggle" data-wp-bind--aria-expanded="context.isOpen" aria-controls="<?php echo esc_attr( $storepress_unique_id ); ?>">
		<?php esc_html_e( 'Toggle me ', '{{textdomain}}' ); ?>
	</button>

	<div id="<?php echo esc_attr( $storepress_unique_id ); ?>" data-wp-bind--hidden="!context.isOpen">
		<?php echo wp_kses( $content, ${{namespace}}_allowed_html ); ?>
	</div>
</div>